---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

const siteUrl = import.meta.env.SITE || 'https://bestaidetector.tools';
const pages = [
  { title: "Best Image Detection", href: "/category/image-detection" },
  { title: "Best Text Detection", href: "/category/text-detection" },
];

const answer =
  `Our "best tools" guides round up the top picks for each use case, comparing the leading options by rating, features, and pricing. Browse the ${pages.length} curated guides below to find the best fit for your needs in 2026.`;

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Best Of' },
      ],
    },
    {
      '@type': 'ItemList',
      name: 'Best tools guides',
      numberOfItems: pages.length,
      itemListElement: pages.map((p, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: p.title,
        url: `${siteUrl}${p.href}`,
      })),
    },
  ],
};
---

<BaseLayout
  title="Best Tools — Comparison Guides (2026)"
  description={`Expert best-of guides comparing the top tools across every category. ${pages.length} curated comparisons, updated for 2026.`}
  schema={schema}
>
  <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
    <a href="/" class="hover:text-blue-600">Home</a>
    <span>/</span>
    <span>Best Of</span>
  </div>

  <h1 class="text-3xl font-bold mb-3">Best Tools — Comparison Guides</h1>

  <section class="mb-8 bg-blue-50 border border-blue-100 rounded-lg p-5">
    <p class="text-gray-800 leading-relaxed">{answer}</p>
  </section>

  <div class="grid gap-6">
    {pages.map((p) => (
      <a href={p.href} class="block border rounded-lg p-6 hover:shadow-md hover:border-blue-300 transition-all">
        <h2 class="text-xl font-semibold mb-1">{p.title}</h2>
      </a>
    ))}
  </div>
</BaseLayout>
