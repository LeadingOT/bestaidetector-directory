---
import FAQ from '../components/FAQ.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import ListingCard from '../components/ListingCard.astro';
import { getCollection } from 'astro:content';

const allListings = await getCollection('listings');
const categories = ['Text Detection', 'Image Detection', 'Video Detection'];
const groupedListings = categories.map(cat => ({
  name: cat,
  slug: cat.toLowerCase().replace(/\s+/g, '-'),
  tools: allListings.filter(l => l.data.category === cat)
}));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Best AI Detector Tools',
  description: 'Compare the best AI detection tools for text, images, and videos',
  url: Astro.url.origin,
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Best AI Detector Tools 2026",
  "description": "Compare and review the top 18 tools in this category",
  "numberOfItems": 18,
  "url": "https://bestaidetector.tools"
};
---

<BaseLayout
  title="Best AI Content Detectors: 10+ Tested & Ranked [2026 Guide]"
  description="10+ AI detectors tested. GPTZero, Turnitin, Winston AI. See accuracy rates, pricing, false positives. Updated March 2026 →"
  schema={itemListSchema}
>
  <!-- Hero -->
  <section class="text-center py-12">
    <h1 class="text-4xl font-bold mb-4">Best AI Detector Tools (2026)</h1>
    <p class="text-lg text-gray-600 max-w-2xl mx-auto">
      Discover and compare the top AI detection tools to identify AI-generated text, images, and videos. Trusted by educators, publishers, and content teams worldwide.
    </p>
  </section>

  <!-- Category Sections -->
  {groupedListings.map(({ name, slug, tools }) => tools.length > 0 && (
    <section class="mb-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold">{name}</h2>
        <a href={`/category/${slug}`} class="text-blue-600 hover:underline text-sm">View all →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {tools.map((listing) => (
          <ListingCard {...listing.data} />
        ))}
      </div>
    </section>
  ))}
  <FAQ />
</BaseLayout>
