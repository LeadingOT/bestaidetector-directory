---
import BaseLayout from '../layouts/BaseLayout.astro';
import ListingCard from '../components/ListingCard.astro';
import { getCollection } from 'astro:content';

const allListings = await getCollection('listings');
const categories = [...new Set(allListings.map((l) => l.data.category))];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'AI Tools for Accounting',
  description: 'Find the best AI tools for accounting, bookkeeping, tax preparation, and financial management',
  url: Astro.url.origin,
};
---

<BaseLayout
  title="Best AI Tools for Accounting & Bookkeeping (2026)"
  description="Compare the best AI-powered accounting, bookkeeping, tax prep, invoicing, and financial management tools. Features, pricing, and expert reviews."
  schema={schema}
>
  <!-- Hero with gradient background -->
  <section class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-blue-600 via-indigo-600 to-purple-600 text-white py-20 px-8 mb-12 shadow-2xl">
    <div class="absolute inset-0 bg-grid-white/[0.05] bg-[size:20px_20px]"></div>
    <div class="relative text-center max-w-3xl mx-auto">
      <div class="inline-block mb-4 px-4 py-1.5 bg-white/20 backdrop-blur-sm rounded-full text-sm font-medium">
        ✨ Updated for 2026
      </div>
      <h1 class="text-5xl font-black mb-6 leading-tight">
        Best AI Tools for<br/>Accounting & Bookkeeping
      </h1>
      <p class="text-xl text-blue-100 mb-8 leading-relaxed">
        Discover and compare the top AI-powered tools for accounting, bookkeeping, tax preparation, invoicing, and financial management.
      </p>
      <div class="flex gap-4 justify-center">
        <a href="#listings" class="px-8 py-3 bg-white text-blue-600 rounded-xl font-semibold hover:shadow-xl transition-all hover:scale-105">
          Explore Tools
        </a>
        <a href="/categories" class="px-8 py-3 bg-white/10 backdrop-blur-sm text-white rounded-xl font-semibold border-2 border-white/20 hover:bg-white/20 transition-all">
          Browse Categories
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="grid md:grid-cols-3 gap-6 mb-12">
    <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
      <div class="text-4xl font-bold text-blue-600 mb-2">{allListings.length}+</div>
      <div class="text-sm text-gray-600">AI Tools Listed</div>
    </div>
    <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
      <div class="text-4xl font-bold text-indigo-600 mb-2">{categories.length}</div>
      <div class="text-sm text-gray-600">Categories</div>
    </div>
    <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
      <div class="text-4xl font-bold text-purple-600 mb-2">2026</div>
      <div class="text-sm text-gray-600">Latest Updates</div>
    </div>
  </section>

  <!-- Categories -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-6 text-gray-900">Browse by Category</h2>
    <div class="flex flex-wrap gap-3">
      {categories.map((cat) => (
        <a
          href={`/category/${cat.toLowerCase().replace(/\s+/g, '-')}`}
          class="px-5 py-2.5 bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 rounded-xl text-sm font-medium text-blue-700 hover:from-blue-100 hover:to-indigo-100 hover:shadow-md transition-all hover:scale-105"
        >
          {cat}
        </a>
      ))}
    </div>
  </section>

  <!-- Listings Grid -->
  <section id="listings">
    <h2 class="text-2xl font-bold mb-6 text-gray-900">All Tools</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {allListings.map((listing) => (
        <ListingCard {...listing.data} />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .bg-grid-white {
    background-image: linear-gradient(to right, rgba(255,255,255,0.1) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.1) 1px, transparent 1px);
  }
</style>
