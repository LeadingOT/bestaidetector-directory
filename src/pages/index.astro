---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const listings = await getCollection('listings');
const sortedListings = listings.sort((a, b) => {
  const aIsFree = a.data.pricingType === 'free';
  const bIsFree = b.data.pricingType === 'free';
  if (aIsFree && !bIsFree) return -1;
  if (!aIsFree && bIsFree) return 1;
  return 0;
});
---

<BaseLayout 
  title="Best AI Detector Tools (2026) - Detect AI-Generated Content"
  description="Compare the best AI detection tools for text, image, and video. Used by educators, content teams, and publishers. Free trials available."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Hero Section -->
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Best AI Detector Tools
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Find the best AI detection tools to identify AI-generated text, images, and videos. Trusted by educators, publishers, and content teams worldwide.
      </p>
    </div>

    <!-- Categories -->
    <div class="grid md:grid-cols-3 gap-6 mb-12">
      <a href="#text-detection" class="p-6 bg-blue-50 rounded-lg hover:bg-blue-100 transition">
        <h3 class="text-xl font-semibold mb-2">📝 Text Detection</h3>
        <p class="text-gray-600">Detect AI-generated text and essays</p>
      </a>
      <a href="#image-detection" class="p-6 bg-purple-50 rounded-lg hover:bg-purple-100 transition">
        <h3 class="text-xl font-semibold mb-2">🖼️ Image Detection</h3>
        <p class="text-gray-600">Identify AI-generated images</p>
      </a>
      <a href="#video-detection" class="p-6 bg-green-50 rounded-lg hover:bg-green-100 transition">
        <h3 class="text-xl font-semibold mb-2">🎥 Video Detection</h3>
        <p class="text-gray-600">Detect deepfakes and AI videos</p>
      </a>
    </div>

    <!-- Tools Grid -->
    <div id="text-detection" class="mb-16">
      <h2 class="text-3xl font-bold mb-8">Text AI Detectors</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedListings.map((listing) => (
          <a 
            href={`/listing/${listing.id}`}
            class="block p-6 bg-white border border-gray-200 rounded-lg hover:shadow-lg transition"
          >
            <h3 class="text-xl font-semibold mb-2">{listing.data.name}</h3>
            <p class="text-gray-600 text-sm mb-4">{listing.data.description}</p>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-500">{listing.data.pricing}</span>
              <span class="text-blue-600 hover:text-blue-800">View →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
